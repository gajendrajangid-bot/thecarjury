{
  "name": "tcj-forum-api",
  "version": "1.0.0",
  "description": "The Car Jury community forum — Cloudflare Workers backend",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev --local",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create tcj-forum",
    "db:schema": "wrangler d1 execute tcj-forum --file=./schema.sql",
    "db:schema:local": "wrangler d1 execute tcj-forum --local --file=./schema.sql",
    "kv:create": "wrangler kv:namespace create tcj-forum-kv",
    "r2:create": "wrangler r2 bucket create tcj-forum-media",
    "setup": "npm run db:create && npm run kv:create && npm run r2:create"
  },
  "devDependencies": {
    "wrangler": "^3.80.0"
  }
}
